# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
LLM_API_KEY=728751ed7b3e4171b3ee1035c1b9af00._L_NA0X_4MSx2rPOZD3tqaNp
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen2.5-7b-instruct
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# ── Ollama Embeddings ─────────────────────────────────────────────────────────
OLLAMA_EMBEDDING_URL=http://localhost:11434/api/embeddings
EMBEDDING_MODEL=nomic-embed-text
VECTOR_DIMENSION=768

# ── FAISS / Vector Store ──────────────────────────────────────────────────────
VECTOR_DB_PATH=./data/faiss
TOP_K_RESULTS=5

# ── SQLite Metadata ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/metadata.db

# ── Firebase Authentication ───────────────────────────────────────────────────
# Download your service account key from Firebase Console > Project Settings > Service accounts
FIREBASE_PROJECT_ID="context-aware-f23c6"
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase_service_account.json

# ── Gmail / Google OAuth ──────────────────────────────────────────────────────
# Download from Google Cloud Console > APIs > Credentials > OAuth 2.0 Client
GMAIL_CLIENT_SECRET_PATH=./config/gmail_client_secret.json
GMAIL_TOKEN_PATH=./data/gmail_token.json
# Must match an authorized redirect URI in your Google Cloud Console OAuth app
GOOGLE_REDIRECT_URI=http://localhost:8000/gmail/callback
# Frontend base URL (used to redirect browser after OAuth completes)
FRONTEND_URL=http://localhost:5173

# ── File Storage ──────────────────────────────────────────────────────────────
OBJECT_STORAGE_PATH=./data/uploads

# ── App Settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,csv,txt
LOG_LEVEL=INFO
