# ── LLM (Local Ollama) ───────────────────────────────────────────────────
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:0.5b
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# ── Embeddings (local sentence-transformers, no API needed) ───────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# ── FAISS / Vector Store ──────────────────────────────────────────────────────
VECTOR_DB_PATH=./data/faiss
TOP_K_RESULTS=15

# ── SQLite Metadata ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/metadata.db

# ── Firebase Authentication ───────────────────────────────────────────────────
# Download your service account key from Firebase Console > Project Settings > Service accounts
FIREBASE_PROJECT_ID="context-aware-f23c6"
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase_service_account.json
ALLOW_UNAUTHENTICATED_ACCESS=true

# ── Gmail OAuth ──────────────────────────────────────────────────────
# Download from Google Cloud Console > APIs > Credentials > OAuth 2.0 Client
GMAIL_CLIENT_SECRET_PATH=./config/gmail_client_secret.json
GMAIL_TOKEN_PATH=./data/gmail_token.json
# Must match authorized redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/gmail/callback
# Frontend URL for post-OAuth browser redirect
FRONTEND_URL=http://localhost:5173

# ── File Storage ──────────────────────────────────────────────────────────────
OBJECT_STORAGE_PATH=./data/uploads

# ── App Settings ─────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,csv,txt
LOG_LEVEL=INFO
